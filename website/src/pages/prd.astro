// website/src/pages/prd.astro
---
import fs from 'node:fs/promises';
import path from 'node:path';

const prdPath = path.resolve(import.meta.url, '../../../_evo-output/planning/zapcart/prd.md');
const markdown = await fs.readFile(prdPath, 'utf-8');
---
<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ZapCart – PRD</title>
    <meta name="description" content="Documento de Requisitos do Produto ZapCart" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles/prd.css" />
  </head>
  <body class="prd-page">
    <header class="header"><h1>ZapCart – Product Requirements Document</h1></header>
    <main class="content"><article class="markdown" set:html={markdown} /></main>
    <footer class="footer"><p>© 2026 ZapCart – 2MLAB</p></footer>
  </body>
</html>
