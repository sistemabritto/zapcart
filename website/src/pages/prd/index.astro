    </div>
  </header>

  <main class="content">
    <div class="glass-card">
      <article class="markdown">
        <Content />
      </article>
    </div>
  </main>

  <footer class="footer">
    <p>© 2026 ZapCart • Desenvolvido para a 2M LAB</p>
  </footer>
